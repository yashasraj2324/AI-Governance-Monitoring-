# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# NVIDIA_API_KEY: Required for Nvidia API calls.
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# GROQ_API_KEY: Required for Groq AI API calls.
GROQ_API_KEY="MY_GROQ_API_KEY"

# SUPABASE_URL: Required for history and persistence
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"

# SUPABASE_ANON_KEY: Required for history and persistence
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# CHROMA_TENANT: Tenant name for multi-tenant deployments (optional)
CHROMA_TENANT="default_tenant"

# CHROMA_DATABASE: Database name to connect to (optional)
CHROMA_DATABASE="default_database"

# CHROMA_API_KEY: Optional API key for authenticating with ChromaDB cloud
CHROMA_API_KEY="YOUR_CHROMA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
